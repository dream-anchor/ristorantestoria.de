RewriteEngine On

# ============================================
# 0. WWW Kanonisierung (SEO)
# ============================================
# HTTPS wird providerseitig bei IONOS erzwungen (nicht via .htaccess)

RewriteCond %{HTTP_HOST} ^ristorantestoria\.de$ [NC]
RewriteRule ^(.*)$ https://www.ristorantestoria.de/$1 [R=301,L]

# ============================================
# 1. Canonical Redirect: /ristorantestoria-de/... → /...
# ============================================
# Entfernt den Ordnernamen aus der URL (301 Redirect)
RewriteCond %{THE_REQUEST} \s/ristorantestoria-de/(\S*)\s [NC]
RewriteRule ^ /%1 [R=301,L]

RewriteCond %{THE_REQUEST} \s/ristorantestoria-de\s [NC]
RewriteRule ^ / [R=301,L]

# ============================================
# 2. Spezielle Weiterleitungen (Query-String)
# ============================================
RewriteCond %{QUERY_STRING} ^page_id=2881$
RewriteRule ^$ /impressum? [R=301,L]

RewriteCond %{QUERY_STRING} ^page_id=3539$
RewriteRule ^(.*)$ /? [R=301,L]

RewriteCond %{QUERY_STRING} ^page_id=2505$
RewriteRule ^(.*)$ /? [R=301,L]

# ============================================
# 3. 301 Redirects für alte URLs
# ============================================
RewriteRule ^mittagsmenu/?$ /mittags-menu/ [R=301,L]
RewriteRule ^weihnachtsmenues/?$ /besondere-anlaesse/weihnachtsmenue/ [R=301,L]
RewriteRule ^silvesterparty/?$ /besondere-anlaesse/silvester/ [R=301,L]
RewriteRule ^lunch-muenchen/?$ /lunch-muenchen-maxvorstadt/ [R=301,L]
RewriteRule ^mittagessen-maxvorstadt/?$ /lunch-muenchen-maxvorstadt/ [R=301,L]
RewriteRule ^eventlocation-muenchen/?$ /eventlocation-muenchen-maxvorstadt/ [R=301,L]
RewriteRule ^italiener-muenchen/?$ / [R=301,L]
# Phantom-URL aus GSC → Ostermontag-Menu
RewriteRule ^besondere-anlaesse/neuer-anlass/?$ /besondere-anlaesse/ostermontag-menue/ [R=301,L]
RewriteRule ^it/occasioni-speciali/neuer-anlass/?$ /it/occasioni-speciali/menu-di-pasqua/ [R=301,L]
RewriteRule ^en/special-occasions/neuer-anlass/?$ /en/special-occasions/easter-monday-menu/ [R=301,L]
RewriteRule ^fr/occasions-speciales/neuer-anlass/?$ /fr/occasions-speciales/menu-de-paques/ [R=301,L]
# Osterbrunch → Ostermontag-Menu (URL-Umbenennung 2026)
RewriteRule ^besondere-anlaesse/osterbrunch/?$ /besondere-anlaesse/ostermontag-menue/ [R=301,L]
RewriteRule ^en/special-occasions/easter-brunch/?$ /en/special-occasions/easter-monday-menu/ [R=301,L]
RewriteRule ^it/occasioni-speciali/pranzo-di-pasqua/?$ /it/occasioni-speciali/menu-di-pasqua/ [R=301,L]
RewriteRule ^fr/occasions-speciales/brunch-de-paques/?$ /fr/occasions-speciales/menu-de-paques/ [R=301,L]
# /menu → /speisekarte (Thin Content entfernt)
RewriteRule ^menu/?$ /speisekarte/ [R=301,L]
RewriteRule ^en/menu/?$ /speisekarte/ [R=301,L]
RewriteRule ^it/menu/?$ /speisekarte/ [R=301,L]
RewriteRule ^fr/menu/?$ /speisekarte/ [R=301,L]

# ============================================
# 3a. Legacy CMS Redirects (WordPress → Neue Seiten)
# ============================================
# /cms/* URLs aus dem alten WordPress. Müssen im Root-htaccess stehen,
# da das Subdirectory keinen /cms/ Ordner hat und der SPA-Fallback
# die Regeln im inneren htaccess nie erreichen lässt.
RewriteRule ^cms/speisekarte/?$ /speisekarte/ [R=301,L]
RewriteRule ^cms/1753-2/?$ /kontakt/ [R=301,L]
RewriteRule ^cms/wp-content/uploads/2025/12/Mittagskarte-01\.12\.2025\.pdf$ /mittags-menu/ [R=301,L]
RewriteRule ^cms/wp-content/uploads/2025/03/Mittagskarte-Deutsch-25\.03\.2025-din\.pdf$ /mittags-menu/ [R=301,L]
RewriteRule ^cms/getraenke/?$ /getraenke/ [R=301,L]
RewriteRule ^cms/weihnachtsmenues-2/?$ /besondere-anlaesse/weihnachtsmenue/ [R=301,L]
RewriteRule ^cms/impressum/?$ /impressum/ [R=301,L]
RewriteRule ^cms/our-team/?$ /ueber-uns/ [R=301,L]
RewriteRule ^cms/reservations/?$ /reservierung/ [R=301,L]
RewriteRule ^cms/events(-2)?/?$ /besondere-anlaesse/ [R=301,L]
RewriteRule ^cms/catering/?$ /catering/ [R=301,L]
RewriteRule ^cms/menue/?$ /mittags-menu/ [R=301,L]
RewriteRule ^cms/speisekarte-2/?$ /speisekarte/ [R=301,L]
RewriteRule ^cms/front-page-2/?$ /? [R=301,L]
# Soft 404 Fix
Redirect 301 /ristorantestoria-de/ https://www.ristorantestoria.de/
# Alle wp-content/uploads → /mittags-menu/
RewriteRule ^cms/wp-content/uploads/ /mittags-menu/ [R=301,L]
# CMS Catch-All: Alle verbleibenden /cms/* → Startseite
RewriteRule ^cms/?$ /? [R=301,L]
RewriteRule ^cms/(.+)$ /? [R=301,L]

# ============================================
# 3b. Trailing Slash erzwingen (vor Subdirectory-Rewrite)
# ============================================
# Alle URLs ohne Trailing Slash → 301 → mit Trailing Slash
# Ausnahmen: Root /, Dateien mit Extension, bereits interne Pfade
RewriteCond %{REQUEST_URI} !^/$
RewriteCond %{REQUEST_URI} !/$
RewriteCond %{REQUEST_URI} !\.[a-zA-Z0-9]+$
RewriteCond %{REQUEST_URI} !^/ristorantestoria-de/
RewriteRule ^(.*)$ /$1/ [R=301,L]

# ============================================
# 4. Interne Rewrites auf /ristorantestoria-de/
# ============================================
# Bedient Requests aus dem Unterordner, ohne die URL zu ändern

# Wenn die Datei im Unterordner existiert (Assets, etc.)
RewriteCond %{REQUEST_URI} !^/ristorantestoria-de/
RewriteCond %{DOCUMENT_ROOT}/ristorantestoria-de%{REQUEST_URI} -f
RewriteRule ^(.*)$ /ristorantestoria-de/$1 [L]

# Wenn VERZEICHNIS im Unterordner existiert (pre-gerenderte Seiten)
RewriteCond %{REQUEST_URI} !^/ristorantestoria-de/
RewriteCond %{DOCUMENT_ROOT}/ristorantestoria-de%{REQUEST_URI} -d
RewriteRule ^(.*)$ /ristorantestoria-de/$1 [L]

# SPA-Fallback: Alle anderen Routen → index.html im Unterordner
RewriteCond %{REQUEST_URI} !^/ristorantestoria-de/
RewriteCond %{REQUEST_FILENAME} !-f
RewriteCond %{REQUEST_FILENAME} !-d
RewriteRule ^ /ristorantestoria-de/index.html [L]

# ============================================
# 5. MIME-Types
# ============================================
<IfModule mod_mime.c>
  AddType application/javascript .js
  AddType text/css .css
  AddType image/webp .webp
  AddType image/svg+xml .svg
  AddType font/woff2 .woff2
  AddType application/xml .xml
  AddType text/plain .txt
</IfModule>

# ============================================
# 6. GZIP-Komprimierung
# ============================================
<IfModule mod_deflate.c>
  AddOutputFilterByType DEFLATE text/html text/css application/javascript application/json image/svg+xml
</IfModule>

# ============================================
# 7. Browser-Caching
# ============================================
<IfModule mod_expires.c>
  ExpiresActive On
  ExpiresByType image/webp "access plus 1 year"
  ExpiresByType image/svg+xml "access plus 1 year"
  ExpiresByType font/woff2 "access plus 1 year"
  ExpiresByType text/css "access plus 1 month"
  ExpiresByType application/javascript "access plus 1 month"
</IfModule>
