# ============================================
# Root .htaccess — NUR Subdirectory-Rewriting
# ============================================
# IONOS: Redirects (301) funktionieren hier NICHT.
# Alle Redirects stehen in ristorantestoria-de/.htaccess
# Diese Datei dient NUR dazu, Requests ins Subdirectory zu leiten.

RewriteEngine On

# non-www → www (wird providerseitig bei IONOS erzwungen, hier als Backup)
RewriteCond %{HTTP_HOST} ^ristorantestoria\.de$ [NC]
RewriteRule ^(.*)$ https://www.ristorantestoria.de/$1 [R=301,L]

# /ristorantestoria-de/ aus URL entfernen
RewriteCond %{THE_REQUEST} \s/ristorantestoria-de/(\S*)\s [NC]
RewriteRule ^ /%1 [R=301,L]

RewriteCond %{THE_REQUEST} \s/ristorantestoria-de\s [NC]
RewriteRule ^ / [R=301,L]

# --- Ab hier: Internes Rewriting (kein 301) ---

# Datei im Unterordner → direkt ausliefern
RewriteCond %{REQUEST_URI} !^/ristorantestoria-de/
RewriteCond %{DOCUMENT_ROOT}/ristorantestoria-de%{REQUEST_URI} -f
RewriteRule ^(.*)$ /ristorantestoria-de/$1 [L]

# Verzeichnis im Unterordner → direkt ausliefern (pre-gerenderte Seiten)
RewriteCond %{REQUEST_URI} !^/ristorantestoria-de/
RewriteCond %{DOCUMENT_ROOT}/ristorantestoria-de%{REQUEST_URI} -d
RewriteRule ^(.*)$ /ristorantestoria-de/$1 [L]

# SPA-Fallback
RewriteCond %{REQUEST_URI} !^/ristorantestoria-de/
RewriteCond %{REQUEST_FILENAME} !-f
RewriteCond %{REQUEST_FILENAME} !-d
RewriteRule ^ /ristorantestoria-de/index.html [L]
